; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GodotWE"
config/description="SMM:WE in Godot"
config/version="0.1.0"
run/main_scene="uid://qepmxcf7odg6"
config/use_custom_user_dir=true
config/features=PackedStringArray("4.6", "Mobile")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
boot_splash/stretch_mode=0
boot_splash/use_filter=false
config/icon="uid://god0ayqmlgrj"
config/windows_native_icon="res://icon.ico"

[audio]

buses/default_bus_layout="res://resources/default_bus_layout.tres"

[autoload]

Utility="*res://scripts/singletons/utility.gd"
UISoundPlayer="*res://scripts/singletons/ui_sound_player.gd"
SceneManager="*res://scripts/singletons/scene_manager.gd"
GameSettings="*res://scripts/singletons/game_settings.gd"
MainMenu="*uid://cqa781bc5m3v7"
MusicPlayer="*uid://b57y74tgiebkd"

[debug]

file_logging/enable_file_logging=true
file_logging/log_path="user://game.log"

[display]

window/size/initial_position_type=4
window/subwindows/embed_subwindows=false
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_height"
mouse_cursor/custom_image_hotspot=Vector2(15, 18)

[editor]

movie_writer/video_quality=1.0
movie_writer/audio_bit_depth=32
movie_writer/ogv/audio_quality=1.0
movie_writer/ogv/encoding_speed=1
movie_writer/movie_file="C:/Users/NCubs/Code/Godot/Super Secret/extra/video.avi"

[editor_plugins]

enabled=PackedStringArray("res://addons/terrain_icon_gen/plugin.cfg")

[file_customization]

folder_colors={
"res://audio/": "red",
"res://extra/": "pink",
"res://resources/": "orange",
"res://scenes/": "yellow",
"res://scripts/": "green",
"res://shaders/": "teal",
"res://textures/": "blue",
"res://textures/player/mario/": "red",
"res://translations/": "purple"
}

[game]

levels/protocol_version=0
levels/allow_swe=true
user/session_token=""
user/username="Player"

[global_group]

map=""
player=""
shadows=""
camera=""
editor="The Editor control node"
editor_map=""
level=""

[gui]

theme/custom="uid://cpr7p83ljnpes"
theme/custom_font="uid://bk3vwucreh07k"

[importer_defaults]

texture={
&"svg/scale": 3.0
}
svg={
"base_scale": 3.0,
"color_map": {},
"compress": true,
"saturation": 1.0
}

