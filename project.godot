; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Super Secret"
config/version="0.1.0"
run/main_scene="uid://cbc3kaegk4jn3"
config/features=PackedStringArray("4.5", "Mobile")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
boot_splash/fullsize=false
boot_splash/use_filter=false
config/icon="uid://god0ayqmlgrj"
config/windows_native_icon="res://icon.ico"

[autoload]

Utility="*res://scripts/singletons/utility.gd"
UISoundPlayer="*res://scripts/singletons/ui_sound_player.gd"
SceneManager="*res://scripts/singletons/scene_manager.gd"
GameSettings="*res://scripts/singletons/game_settings.gd"

[debug]

file_logging/enable_file_logging=true
file_logging/log_path="user://game.log"

[display]

window/subwindows/embed_subwindows=false
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_height"
mouse_cursor/custom_image_hotspot=Vector2(15, 18)

[editor]

movie_writer/movie_file="C:/Users/NCubs/Code/Godot/Super Secret/Intro.ogv"

[file_customization]

folder_colors={
"res://audio/": "red",
"res://scenes/": "yellow",
"res://scripts/": "green",
"res://sprites/": "blue",
"res://sprites/player/mario/": "red"
}

[global_group]

map=""
player=""
shadows=""
camera=""
editor="The Editor control node"
editor_map=""

[gui]

theme/custom="uid://cpr7p83ljnpes"
theme/custom_font="uid://bk3vwucreh07k"

[importer_defaults]

texture={
&"svg/scale": 3.0
}

